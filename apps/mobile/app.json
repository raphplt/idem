{
  "expo": {
    "name": "idem",
    "slug": "idem",
    "version": "0.0.1",
    "scheme": "idem",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.raphplt.idem",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.raphplt.idem",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-image",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0d0d12"
        }
      ],
      "expo-sharing",
      "expo-secure-store",
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-notifications",
      [
        "expo-media-library",
        {
          "savePhotosPermission": "idem enregistre l'image de ton passeport de goût dans tes photos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "idem utilise ta position pour contextualiser les suggestions autour de toi."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "40857ddf-24a6-495b-a8a9-1d74d5fec9fa"
      }
    },
    "owner": "raphplt",
    "updates": {
      "url": "https://u.expo.dev/40857ddf-24a6-495b-a8a9-1d74d5fec9fa"
    }
  }
}
