# Base de données (docker compose expose le port 5433 pour éviter les collisions avec un Postgres local)
DATABASE_URL=postgres://idem:idem@localhost:5433/idem

# API
API_PORT=3000

# Pipeline d'ingestion — clé TMDB (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=

# Mobile — URL de l'API vue depuis le téléphone.
# En simulateur iOS : http://localhost:3000. Sur un vrai appareil : http://<ip-locale-du-mac>:3000
EXPO_PUBLIC_API_URL=http://localhost:3000
